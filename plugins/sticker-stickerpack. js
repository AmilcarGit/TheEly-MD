import fetch from 'node-fetch'
import {
  generateWAMessageFromContent,
  prepareWAMessageMedia,
  proto
} from '@whiskeysockets/baileys'

const API_URL = 'https://apiyosoyyo-ofc.onrender.com/api/stickerpack'
const API_KEY = 'yosoyyo_sk_7bzwo41b'

function crearMensaje(chat, text, buttons, m, media = null) {
  const interactiveMessage = proto.Message.InteractiveMessage.create({
    header: {
      title: '🌼 THEELY-MD — STICKERPACK',
      subtitle: 'Busca y descarga packs de stickers~',
      hasMediaAttachment: !!media?.imageMessage,
      ...(media?.imageMessage && { imageMessage: media.imageMessage })
    },
    body: { text },
    footer: { text: '💫 Powered by TheEly-MD 🌼' },
    nativeFlowMessage: { buttons }
  })

  return generateWAMessageFromContent(
    chat,
    { viewOnceMessage: { message: { messageContextInfo: {}, interactiveMessage } } },
    { quoted: m }
  )
}

let handler = async (m, { conn, text, usedPrefix, command }) => {
  if (!text) {
    const bodyText = [
      `╔══〔 🖼️ *THEELY-MD — STICKERPACK* 〕══╗`,
      `║`,
      `║ 💡 *Uso:* ${usedPrefix + command} <búsqueda>`,
      `║ 📌 *Ejemplo:* ${usedPrefix + command} anime`,
      `║`,
      `╚══════════════════════════════════╝`
    ].join('\n')

    const buttons = [{
      name: 'single_select',
      buttonParamsJson: JSON.stringify({
        title: '🖼️ Ayuda Stickerpack',
        sections: [{
          title: 'ℹ️ Información',
          rows: [{
            title: '📖 Cómo usar',
            description: 'Escribe el nombre del pack que buscas',
            id: `sp_help_${m.chat}`
          }]
        }]
      })
    }]

    const msg = crearMensaje(m.chat, bodyText, buttons, m)
    await conn.relayMessage(m.chat, msg.message, { messageId: msg.key.id })
    return
  }

  const query = text.trim()
  await m.react('🔍')

  try {
    await conn.sendMessage(m.chat, {
      text: [
        `╔══〔 🖼️ *THEELY-MD — STICKERPACK* 〕══╗`,
        `║`,
        `║ 🔍 *Buscando:* ${query}`,
        `║ ⏳ Por favor espera~`,
        `║`,
        `╚══════════════════════════════════╝`
      ].join('\n')
    }, { quoted: m })

    const res = await Promise.race([
      fetch(`${API_URL}?q=${encodeURIComponent(query)}&apiKey=${API_KEY}`),
      new Promise((_, rej) => setTimeout(() => rej(new Error('timeout')), 15000))
    ])
    const json = await res.json()

    if (!json.status || !json.result?.data?.length) {
      throw new Error('Sin resultados')
    }

    const resultados = json.result.data.slice(0, 10)

    let media = null
    const primeraImg = resultados[0]?.image || ''
    if (primeraImg) {
      try {
        media = await prepareWAMessageMedia(
          { image: { url: primeraImg } },
          { upload: conn.waUploadToServer }
        )
      } catch {}
    }

    const rows = resultados.map((pack, i) => {
      const nombreB64 = Buffer.from(pack.name || '').toString('base64')
      const urlB64 = Buffer.from(pack.url || '').toString('base64')
      const numero = ['1️⃣','2️⃣','3️⃣','4️⃣','5️⃣','6️⃣','7️⃣','8️⃣','9️⃣','🔟'][i] || '🔢'
      return {
        header: `${numero} ${pack.name || 'Sin nombre'}`,
        title: `📦 ${pack.name || 'Sin nombre'}`,
        description: `⬇️ ${pack.download || 0} descargas`,
        id: `sp_${i}_${nombreB64}_${urlB64}`
      }
    })

    const listaTexto = resultados.map((pack, i) => {
      const numero = ['1️⃣','2️⃣','3️⃣','4️⃣','5️⃣','6️⃣','7️⃣','8️⃣','9️⃣','🔟'][i] || '🔢'
      return [
        `║ ${numero} *${pack.name || 'Sin nombre'}*`,
        `║   ⬇️ ${pack.download || 0} descargas`,
        `║`
      ]
    }).flat()

    const bodyText = [
      `╔══〔 🖼️ *THEELY-MD — STICKERPACK* 〕══╗`,
      `║`,
      `║ 🔍 *Búsqueda:* ${query}`,
      `║ 📊 *Resultados:* ${resultados.length}`,
      `║`,
      ...listaTexto,
      `║ 👇 *Elige un pack~*`,
      `║`,
      `╚══════════════════════════════════╝`
    ].join('\n')

    const buttons = [{
      name: 'single_select',
      buttonParamsJson: JSON.stringify({
        title: '🖼️ Elige un pack',
        sections: [{ title: `📋 ${query.toUpperCase()}`, rows }]
      })
    }]

    const msg = crearMensaje(m.chat, bodyText, buttons, m, media)
    await conn.relayMessage(m.chat, msg.message, { messageId: msg.key.id })

  } catch (e) {
    console.error('❌ Error en stickerpack:', e.message)
    await m.react('❌')
    m.reply([
      `╔══〔 🖼️ *THEELY-MD — STICKERPACK* 〕══╗`,
      `║`,
      `║ ❌ *Sin resultados para:*`,
      `║ 🔍 ${query}`,
      `║`,
      `║ 💡 Intenta con otro término~`,
      `║`,
      `╚══════════════════════════════════╝`
    ].join('\n'))
  }
}

handler.before = async (m, { conn }) => {
  const nativeFlow = m.message?.interactiveResponseMessage?.nativeFlowResponseMessage
  if (!nativeFlow) return false

  try {
    const data = JSON.parse(nativeFlow.paramsJson || '{}')
    const id = data.id || data.selectedId || null
    if (!id) return false

    if (id.startsWith('sp_help_')) {
      await conn.sendMessage(m.chat, {
        text: [
          `╔══〔 🖼️ *THEELY-MD — STICKERPACK* 〕══╗`,
          `║`,
          `║ 💡 *Envía el comando así:*`,
          `║ .stickerpack anime`,
          `║ .stickerpack gatos`,
          `║`,
          `║ 📌 También puedes usar:`,
          `║ .sp <búsqueda>`,
          `║`,
          `╚══════════════════════════════════╝`
        ].join('\n')
      }, { quoted: m })
      return true
    }

    if (!id.startsWith('sp_')) return false

    const parts = id.split('_')
    const nombreB64 = parts[2]
    const urlB64 = parts[3] || ''
    const nombre = Buffer.from(nombreB64, 'base64').toString()
    const url = Buffer.from(urlB64, 'base64').toString()

    await m.react('⏳')
    await conn.sendMessage(m.chat, {
      text: [
        `╔══〔 🖼️ *THEELY-MD — STICKERPACK* 〕══╗`,
        `║`,
        `║ ⏳ *Abriendo pack...*`,
        `║ 📦 ${nombre.slice(0, 40) || 'Stickerpack'}`,
        `║`,
        `╚══════════════════════════════════╝`
      ].join('\n')
    }, { quoted: m })

    await conn.sendMessage(m.chat, {
      text: [
        `╔══〔 🖼️ *THEELY-MD — STICKERPACK* 〕══╗`,
        `║`,
        `║ ✅ *Pack encontrado~*`,
        `║`,
        `║ 📦 *Nombre:* ${nombre}`,
        `║ 🔗 *Enlace:* ${url}`,
        `║`,
        `║ 💡 *Abre el enlace para ver los stickers*`,
        `║`,
        `║ 💫 *Powered by TheEly-MD 🌼*`,
        `╚══════════════════════════════════╝`
      ].join('\n')
    }, { quoted: m })

    await m.react('✅')
    return true

  } catch (e) {
    console.error('❌ Error en before stickerpack:', e.message)
    await conn.sendMessage(m.chat, {
      text: [
        `╔══〔 🖼️ *THEELY-MD — STICKERPACK* 〕══╗`,
        `║`,
        `║ ❌ *Error al abrir el pack~*`,
        `║ 🔄 Intenta de nuevo`,
        `║`,
        `╚══════════════════════════════════╝`
      ].join('\n')
    }, { quoted: m })
    await m.react('❌')
    return true
  }
}

handler.help = ['stickerpack <búsqueda>']
handler.tags = ['sticker']
handler.command = /^(stickerpack|sp)$/i
handler.desc = 'Busca packs de stickers por nombre'
handler.register = false
handler.limit = false

export default handler