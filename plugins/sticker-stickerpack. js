import fetch from 'node-fetch'
import {
  generateWAMessageFromContent,
  prepareWAMessageMedia,
  proto
} from '@whiskeysockets/baileys'

const API_URL = 'https://apiyosoyyo-ofc.onrender.com/api/stickerpack'
const API_KEY = 'yosoyyo_sk_7bzwo41b'

function crearMensaje(chat, text, buttons, m, media = null) {
  const interactiveMessage = proto.Message.InteractiveMessage.create({
    header: {
      title: '🌼 THEELY-MD — STICKERPACK',
      subtitle: 'Busca y descarga packs de stickers~',
      hasMediaAttachment: !!media?.imageMessage,
      ...(media?.imageMessage && { imageMessage: media.imageMessage })
    },
    body: { text },
    footer: { text: '💫 Powered by TheEly-MD 🌼' },
    nativeFlowMessage: { buttons }
  })

  return generateWAMessageFromContent(
    chat,
    { viewOnceMessage: { message: { messageContextInfo: {}, interactiveMessage } } },
    { quoted: m }
  )
}

let handler = async (m, { conn, text, usedPrefix, command }) => {
  if (!text) {
    const bodyText = [
      `╔══〔 🖼️ *THEELY-MD — STICKERPACK* 〕══╗`,
      `║`,
      `║ 💡 *Uso:* ${usedPrefix + command} <búsqueda>`,
      `║ 📌 *Ejemplo:* ${usedPrefix + command} anime`,
      `║`,
      `╚══════════════════════════════════╝`
    ].join('\n')

    const buttons = [{
      name: 'single_select',
      buttonParamsJson: JSON.stringify({
        title: '🖼️ Ayuda Stickerpack',
        sections: [{
          title: 'ℹ️ Información',
          rows: [{
            title: '📖 Cómo usar',
            description: 'Escribe el nombre del pack que buscas',
            id: `sp_help_${m.chat}`
          }]
        }]
      })
    }]

    const msg = crearMensaje(m.chat, bodyText, buttons, m)
    await conn.relayMessage(m.chat, msg.message, { messageId: msg.key.id })
    return
  }

  const query = text.trim()
  await m.react('🔍')

  try {
    await conn.sendMessage(m.chat, {
      text: [
        `╔══〔 🖼️ *THEELY-MD — STICKERPACK* 〕══╗`,
        `║`,
        `║ 🔍 *Buscando:* ${query}`,
        `║ ⏳ Por favor espera~`,
        `║`,
        `╚══════════════════════════════════╝`
      ].join('\n')
    }, { quoted: m })

    // ====== CONSULTA A LA API ======
    const url = `${API_URL}?q=${encodeURIComponent(query)}&apiKey=${API_KEY}`
    console.log('📡 URL de la API:', url)

    const res = await Promise.race([
      fetch(url),
      new Promise((_, rej) => setTimeout(() => rej(new Error('timeout')), 15000))
    ])

    // Verificar si la respuesta es ok
    if (!res.ok) {
      throw new Error(`Error HTTP: ${res.status} - ${res.statusText}`)
    }

    const json = await res.json()
    console.log('📦 Respuesta de la API:', JSON.stringify(json, null, 2)) // Log para depuración

    // ====== EXTRAER RESULTADOS FLEXIBLE ======
    let resultados = []
    if (json.status && json.result && json.result.data) {
      resultados = json.result.data
    } else if (json.status && json.data) {
      resultados = json.data
    } else if (json.data && Array.isArray(json.data)) {
      resultados = json.data
    } else if (json.results && Array.isArray(json.results)) {
      resultados = json.results
    } else if (Array.isArray(json)) {
      resultados = json
    } else if (json.packs && Array.isArray(json.packs)) {
      resultados = json.packs
    } else {
      // Intentar encontrar cualquier array en la respuesta
      for (const key of Object.keys(json)) {
        if (Array.isArray(json[key]) && json[key].length > 0) {
          resultados = json[key]
          break
        }
      }
    }

    if (!resultados || resultados.length === 0) {
      throw new Error('Sin resultados')
    }

    // Limitar a 10 resultados
    resultados = resultados.slice(0, 10)

    // ====== PREPARAR IMAGEN PARA EL HEADER ======
    let media = null
    const primeraImg = resultados[0]?.image || resultados[0]?.thumbnail || resultados[0]?.thumb || resultados[0]?.icon || ''
    if (primeraImg) {
      try {
        media = await prepareWAMessageMedia(
          { image: { url: primeraImg } },
          { upload: conn.waUploadToServer }
        )
      } catch (e) {
        console.warn('No se pudo obtener la imagen del header:', e.message)
      }
    }

    // ====== CONSTRUIR FILAS DE BOTONES ======
    const rows = resultados.map((pack, i) => {
      const nombre = pack.name || pack.title || pack.nombre || pack.pack_name || 'Pack sin nombre'
      const url = pack.url || pack.link || pack.download_url || pack.enlace || pack.pack_url || ''
      const descargas = pack.download || pack.downloads || pack.descargas || pack.count || 0
      const nombreB64 = Buffer.from(nombre).toString('base64')
      const urlB64 = Buffer.from(url).toString('base64')
      const numero = ['1️⃣','2️⃣','3️⃣','4️⃣','5️⃣','6️⃣','7️⃣','8️⃣','9️⃣','🔟'][i] || '🔢'
      return {
        header: `${numero} ${nombre.slice(0, 30)}`,
        title: nombre.slice(0, 45),
        description: `⬇️ ${descargas} descargas`,
        id: `sp_${i}_${nombreB64}_${urlB64}`
      }
    })

    // ====== TEXTO DEL MENÚ ======
    const listaTexto = resultados.map((pack, i) => {
      const numero = ['1️⃣','2️⃣','3️⃣','4️⃣','5️⃣','6️⃣','7️⃣','8️⃣','9️⃣','🔟'][i] || '🔢'
      const nombre = pack.name || pack.title || pack.nombre || pack.pack_name || 'Pack sin nombre'
      const descargas = pack.download || pack.downloads || pack.descargas || pack.count || 0
      return [
        `║ ${numero} *${nombre.slice(0, 40)}*`,
        `║   ⬇️ ${descargas} descargas`,
        `║`
      ]
    }).flat()

    const bodyText = [
      `╔══〔 🖼️ *THEELY-MD — STICKERPACK* 〕══╗`,
      `║`,
      `║ 🔍 *Búsqueda:* ${query}`,
      `║ 📊 *Resultados:* ${resultados.length}`,
      `║`,
      ...listaTexto,
      `║ 👇 *Elige un pack~*`,
      `║`,
      `╚══════════════════════════════════╝`
    ].join('\n')

    // ====== BOTÓN INTERACTIVO ======
    const buttons = [{
      name: 'single_select',
      buttonParamsJson: JSON.stringify({
        title: '🖼️ Elige un pack',
        sections: [{ title: `📋 ${query.toUpperCase()}`, rows }]
      })
    }]

    const msg = crearMensaje(m.chat, bodyText, buttons, m, media)
    await conn.relayMessage(m.chat, msg.message, { messageId: msg.key.id })

  } catch (e) {
    console.error('❌ Error en stickerpack:', e.message)
    await m.react('❌')
    m.reply([
      `╔══〔 🖼️ *THEELY-MD — STICKERPACK* 〕══╗`,
      `║`,
      `║ ❌ *Error al buscar:* ${e.message}`,
      `║`,
      `║ 💡 Intenta con otro término~`,
      `║`,
      `╚══════════════════════════════════╝`
    ].join('\n'))
  }
}

handler.before = async (m, { conn }) => {
  const nativeFlow = m.message?.interactiveResponseMessage?.nativeFlowResponseMessage
  if (!nativeFlow) return false

  try {
    const data = JSON.parse(nativeFlow.paramsJson || '{}')
    const id = data.id || data.selectedId || null
    if (!id) return false

    if (id.startsWith('sp_help_')) {
      await conn.sendMessage(m.chat, {
        text: [
          `╔══〔 🖼️ *THEELY-MD — STICKERPACK* 〕══╗`,
          `║`,
          `║ 💡 *Envía el comando así:*`,
          `║ .stickerpack anime`,
          `║ .stickerpack gatos`,
          `║`,
          `║ 📌 También puedes usar:`,
          `║ .sp <búsqueda>`,
          `║`,
          `╚══════════════════════════════════╝`
        ].join('\n')
      }, { quoted: m })
      return true
    }

    if (!id.startsWith('sp_')) return false

    const parts = id.split('_')
    const nombreB64 = parts[2]
    const urlB64 = parts[3] || ''
    const nombre = Buffer.from(nombreB64, 'base64').toString()
    const url = Buffer.from(urlB64, 'base64').toString()

    await m.react('⏳')
    await conn.sendMessage(m.chat, {
      text: [
        `╔══〔 🖼️ *THEELY-MD — STICKERPACK* 〕══╗`,
        `║`,
        `║ ⏳ *Abriendo pack...*`,
        `║ 📦 ${nombre.slice(0, 40) || 'Stickerpack'}`,
        `║`,
        `╚══════════════════════════════════╝`
      ].join('\n')
    }, { quoted: m })

    // Si la URL es válida, la enviamos
    if (url) {
      await conn.sendMessage(m.chat, {
        text: [
          `╔══〔 🖼️ *THEELY-MD — STICKERPACK* 〕══╗`,
          `║`,
          `║ ✅ *Pack encontrado~*`,
          `║`,
          `║ 📦 *Nombre:* ${nombre}`,
          `║ 🔗 *Enlace:* ${url}`,
          `║`,
          `║ 💡 *Abre el enlace para ver los stickers*`,
          `║`,
          `║ 💫 *Powered by TheEly-MD 🌼*`,
          `╚══════════════════════════════════╝`
        ].join('\n')
      }, { quoted: m })
    } else {
      await conn.sendMessage(m.chat, {
        text: [
          `╔══〔 🖼️ *THEELY-MD — STICKERPACK* 〕══╗`,
          `║`,
          `║ ⚠️ *Pack sin enlace disponible*`,
          `║`,
          `║ 📦 *Nombre:* ${nombre}`,
          `║`,
          `║ 💫 *Powered by TheEly-MD 🌼*`,
          `╚══════════════════════════════════╝`
        ].join('\n')
      }, { quoted: m })
    }

    await m.react('✅')
    return true

  } catch (e) {
    console.error('❌ Error en before stickerpack:', e.message)
    await conn.sendMessage(m.chat, {
      text: [
        `╔══〔 🖼️ *THEELY-MD — STICKERPACK* 〕══╗`,
        `║`,
        `║ ❌ *Error al abrir el pack~*`,
        `║ 🔄 Intenta de nuevo`,
        `║`,
        `╚══════════════════════════════════╝`
      ].join('\n')
    }, { quoted: m })
    await m.react('❌')
    return true
  }
}

handler.help = ['stickerpack <búsqueda>']
handler.tags = ['sticker']
handler.command = /^(stickerpack|sp)$/i
handler.desc = 'Busca packs de stickers por nombre'
handler.register = false
handler.limit = false

export default handler