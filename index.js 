const { default: makeWASocket, useMultiFileAuthState, fetchLatestBaileysVersion } = require('@whiskeysockets/baileys');
const { Boom } = require('@hapi/boom');
const pino = require('pino');
const qrcode = require('qrcode-terminal');
const fs = require('fs');
const path = require('path');
const config = require('./config');
const { cargarComandos, ejecutarComando } = require('./src/manejador');

const logger = pino({ level: 'silent' });
let comandos;

async function iniciarBot() {
    // Cargar todos los comandos
    comandos = cargarComandos(path.join(__dirname, 'src', 'comandos'));
    
    const { state, saveCreds } = await useMultiFileAuthState('./session');
    const { version } = await fetchLatestBaileysVersion();

    const sock = makeWASocket({
        version,
        logger,
        printQRInTerminal: true,
        auth: state,
        browser: ['MiNuevoBot-MD', 'Chrome', '1.0.0'],
        getMessage: async (key) => {
            // Implementar si usas store
            return { conversation: 'Mensaje no disponible' };
        }
    });

    sock.ev.on('creds.update', saveCreds);

    sock.ev.on('connection.update', ({ connection, lastDisconnect, qr }) => {
        if (qr) {
            console.clear();
            console.log('🤖 MiNuevoBot-MD - Escanea el QR:');
            qrcode.generate(qr, { small: true });
        }
        
        if (connection === 'close') {
            const deberiaReconectar = (lastDisconnect?.error instanceof Boom) && 
                                      lastDisconnect.error.output.statusCode !== 401;
            console.log('❌ Conexión cerrada. Reconectando:', deberiaReconectar);
            if (deberiaReconectar) iniciarBot();
        } else if (connection === 'open') {
            console.clear();
            console.log('✅ MiNuevoBot-MD conectado exitosamente!');
            console.log(`👑 Owner: ${config.ownerNombre}`);
            console.log(`📌 Prefijo: ${config.prefijo}`);
            console.log(`📦 Comandos cargados: ${comandos.size}`);
        }
    });

    // Manejar mensajes
    sock.ev.on('messages.upsert', async ({ messages }) => {
        const msg = messages[0];
        if (!msg.message || msg.key.fromMe) return;
        
        await ejecutarComando(sock, msg, comandos, config);
        
        // Anti-link (básico)
        if (msg.key.remoteJid.endsWith('@g.us') && config.antiLink) {
            const body = msg.message.conversation || msg.message.extendedTextMessage?.text || '';
            if (body.match(/(https?:\/\/[^\s]+)/) && !msg.key.participant.includes(config.ownerNumero)) {
                await sock.sendMessage(msg.key.remoteJid, { 
                    delete: { remoteJid: msg.key.remoteJid, id: msg.key.id, participant: msg.key.participant }
                });
                await sock.sendMessage(msg.key.remoteJid, { 
                    text: `⚠️ @${msg.key.participant.split('@')[0]} enlaces no permitidos`,
                    mentions: [msg.key.participant]
                });
            }
        }
    });

    // Bienvenida a grupos
    sock.ev.on('group-participants.update', async (update) => {
        if (update.action === 'add' && config.bienvenida) {
            const bienvenida = config.mensajes.bienvenida
                .replace('{user}', `@${update.participants[0].split('@')[0]}`)
                .replace('{grupo}', update.id);
            
            await sock.sendMessage(update.id, {
                text: bienvenida,
                mentions: [update.participants[0]]
            });
        }
    });
}

iniciarBot();